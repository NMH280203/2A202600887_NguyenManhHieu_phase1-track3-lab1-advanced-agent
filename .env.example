# Copy to .env and adjust as needed:
#   cp .env.example .env

# Mock runtime (no LLM). Set to 0 when using Ollama/OpenAI.
MOCK_MODE=0

# --- Ollama (local Llama 3.1) ---
OLLAMA=1
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_MODEL=llama3.1

# Cost estimate in report ($/1M tokens). Use 0 for local Ollama.
REFERENCE_COST_PER_1M_TOKENS=0.15

# --- OpenAI (cloud) — comment Ollama block above and use:
# OLLAMA=0
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o-mini
